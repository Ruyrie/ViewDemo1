<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="HeaderView">
        <attr name="text" format="string"/>
        <attr name="left_text" format="string"/>
        <attr name="right_text" format="string"/>
        <attr name="title_textSize" format="dimension"/>
        <attr name="left_background" format="reference|color"/>
        <attr name="right_background_drawable" format="reference"/>
        <attr name="right_background_color" format="color"/>
        <attr name="left_gravity">
            <flag name="center" value="0"/>
            <flag name="top" value="1"/>
            <flag name="bottom" value="2"/>
        </attr>
    </declare-styleable>
</resources>
